      <xs:documentation>
        <!-- _locID_text="TargetPlatform" _locComment="" -->Target platform in the form of "[Identifier], Version=[Version]", for
        example, "Windows, Version=8.0" </xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="Analyzer" substitutionGroup="Item">
