    <xs:annotation>
      <xs:documentation><!-- _locID_text="CompilerGeneratedFilesOutputPath" _locComment="" -->Controls where source generated files are saved.</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="Configuration" type="StringPropertyType" substitutionGroup="Property" />
  <xs:element name="ConfigurationName" type="StringPropertyType"
