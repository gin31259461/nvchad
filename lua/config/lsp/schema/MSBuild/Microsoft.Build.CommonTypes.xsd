      <xs:restriction base="xs:string">
        <xs:enumeration value="none" />
        <xs:enumeration value="default" />
        <xs:enumeration value="minimum" />
        <xs:enumeration value="recommended" />
        <xs:enumeration value="all" />
      </xs:restriction>
    </xs:simpleType>
  </xs:element>
  <xs:element name="AppConfigForCompiler" type="StringPropertyType"
    substitutionGroup="Property" />
  <xs:element name="ApplicationDefaultFont" type="StringPropertyType"
    substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="ApplicationDefaultFont" _locComment="" -->Customizes the application default font. The format equivalent to the output
        of FontConverter.ConvertToInvariantString(). Applies only to Windows Forms projects.</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="ApplicationHighDpiMode" substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="ApplicationHighDpiMode" _locComment="" -->Customizes the application DPI awareness mode. Applies only to Windows Forms
        projects.</xs:documentation>
    </xs:annotation>
    <xs:simpleType>
      <xs:restriction base="xs:string">
        <xs:enumeration value="SystemAware" />
        <xs:enumeration value="PerMonitorV2" />
        <xs:enumeration value="PerMonitor" />
        <xs:enumeration value="DpiUnaware" />
        <xs:enumeration value="DpiUnawareGdiScaled" />
      </xs:restriction>
    </xs:simpleType>
  </xs:element>
  <xs:element name="ApplicationIcon" type="StringPropertyType" substitutionGroup="Property" />
  <xs:element name="ApplicationRevision" type="StringPropertyType"
    substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="ApplicationRevision" _locComment="" -->integer</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="ApplicationVersion" type="StringPropertyType"
    substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="ApplicationVersion" _locComment="" -->Matches the expression "\d\.\d\.\d\.(\d|\*)"</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="ApplicationUseCompatibleTextRendering" type="boolean"
    substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="ApplicationUseCompatibleTextRendering" _locComment="" -->Indicates whether to set UseCompatibleTextRendering property defined on
        certain controls (boolean). Applies only to Windows Forms projects.</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="ApplicationVisualStyles" type="boolean" substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="ApplicationVisualStyles" _locComment="" -->Indicates whether to enable or disable visual styles (boolean). Applies only
        to Windows Forms projects.</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="AppDesignerFolder" type="StringPropertyType"
    substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="AppDesignerFolder" _locComment="" -->Name of folder for Application Designer</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="AspNetConfiguration" type="StringPropertyType"
    substitutionGroup="Property" />
  <xs:element name="AspNetCoreHostingModel" type="StringPropertyType"
    substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_textPackageId _locComment="" -->Indicates whether to run an ASP.NET Core application using IIS in-process or
        out-of-process.</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="AspNetCoreModuleName" type="StringPropertyType"
    substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_textPackageId _locComment="" -->Indicates which AspNetCoreModule version to use. Versions include V1 and V2.</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="AssemblyKeyContainerName" type="StringPropertyType"
    substitutionGroup="Property" />
  <xs:element name="AssemblyKeyProviderName" type="StringPropertyType"
    substitutionGroup="Property" />
  <xs:element name="AssemblyName" type="StringPropertyType" substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="AssemblyName" _locComment="" -->Name of output assembly</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="AssemblyOriginatorKeyFile" type="StringPropertyType"
    substitutionGroup="Property" />
  <xs:element name="AssemblyOriginatorKeyFileType" type="StringPropertyType"
    substitutionGroup="Property" />
  <xs:element name="AssemblyOriginatorKeyMode" type="StringPropertyType"
    substitutionGroup="Property" />
  <xs:element name="AssemblyType" type="StringPropertyType" substitutionGroup="Property" />
  <xs:element name="AutoGenerateBindingRedirects" type="StringPropertyType"
    substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="AutorunEnabled" _locComment="" -->Indicates whether BindingRedirect elements should be automatically generated
        for referenced assemblies.</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="AutorunEnabled" type="boolean" substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="AutorunEnabled" _locComment="" -->boolean</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="BaseAddress" type="StringPropertyType" substitutionGroup="Property" />
  <xs:element name="BootstrapperComponentsLocation" type="StringPropertyType"
    substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="BootstrapperComponentsLocation" _locComment="" -->HomeSite, Relative, or Absolute</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="BootstrapperComponentsUrl" type="StringPropertyType"
    substitutionGroup="Property" />
  <xs:element name="BootstrapperEnabled" type="boolean" substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="BootstrapperEnabled" _locComment="" -->boolean</xs:documentation>
    </xs:annotation>
