  <xs:element name="ConfigurationOverrideFile" type="StringPropertyType"
    substitutionGroup="Property" />
  <xs:element name="CreateDesktopShortcut" type="boolean" substitutionGroup="Property" />
  <xs:element name="CreateWebPageOnPublish" type="boolean" substitutionGroup="Property">
    <xs:annotation>
      <xs:documentation><!-- _locID_text="CreateWebPageOnPublish" _locComment="" -->boolean</xs:documentation>
    </xs:annotation>
